# 开启后，未登录用户只能看到光构登录页。
VITE_GOUO_BACKEND_ENABLED=true

# 生产环境前后端同域、由反向代理转发 /api 和 /v1 时留空。
# 生产环境前后端不同域时才填写；推荐留空并使用同域反向代理。
VITE_GOUO_BACKEND_URL=

# 仅本地 Vite 开发使用，Vite 会把同域 /api 和 /v1 转发到这里。
VITE_GOUO_BACKEND_DEV_TARGET=http://127.0.0.1:3000

# One Hub 中必须存在同名模型的可用渠道。
VITE_GOUO_IMAGE_MODEL=gpt-image-2
